      "settings": {
        "foreground": "#799EE9",
        "fontStyle": ""
      }
    },
    {
      "name": "Storage modifier (var, const...)",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#799EE9",
        "fontStyle": "italic bold"
