  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7E838B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python code tags",
      "scope": "keyword.codetag.notation.python",
      "settings": {
        "foreground": "#7E838B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#70E19D"
      }
    },
    {
      "name": "String escape / interpolation punctuation",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#E87396"
      }
    },
    {
      "name": "Regexp",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#6BCDE7"
      }
    },
    {
      "name": "Numeric literal",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7F9BE1"
      }
    },
    {
      "name": "LaTeX math symbols",
      "scope": "constant.character.math.tex",
      "settings": {
        "foreground": "#E9C877"
      }
    },
    {
      "name": "LaTeX general math commands",
      "scope": "constant.other.general.math.tex",
      "settings": {
        "foreground": "#6FE7B6"
      }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#799EE9",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Other language constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#799EE9"
      }
    },
    {
      "name": "Python language constants",
      "scope": "constant.language.python",
      "settings": {
        "foreground": "#7F9BE1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword — control flow",
      "scope": [
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.using"
      ],
      "settings": {
        "foreground": "#E8E073",
        "fontStyle": ""
      }
    },
    {
      "name": "LaTeX preamble commands",
      "scope": "keyword.control.preamble.latex",
      "settings": {
        "foreground": "#E9C977",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python import keywords",
      "scope": "keyword.control.import.python",
      "settings": {
        "foreground": "#E9C977",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python control-flow keywords",
      "scope": "keyword.control.flow.python",
      "settings": {
        "foreground": "#E8BB75",
        "fontStyle": "bold"
      }
    },
    {
      "name": "LaTeX label, reference, and citation commands",
      "scope": [
        "keyword.control.label.latex",
        "keyword.control.ref.latex",
        "keyword.control.cite.latex"
      ],
      "settings": {
        "foreground": "#E7B16A"
      }
    },
    {
      "name": "LaTeX equation alignment",
      "scope": [
        "keyword.control.equation.align.latex",
        "keyword.control.equation.newline.latex"
      ],
      "settings": {
        "foreground": "#E97777",
        "fontStyle": "bold"
      }
    },
    {
      "name": "LaTeX table alignment",
      "scope": [
        "keyword.control.table.cell.latex",
        "keyword.control.table.newline.latex"
      ],
      "settings": {
        "foreground": "#E97777",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword — other",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#E8E073"
      }
    },
    {
      "name": "LaTeX list item",
      "scope": "keyword.other.item.latex",
      "settings": {
        "foreground": "#6DE7BB",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#BDBFC3",
        "fontStyle": ""
