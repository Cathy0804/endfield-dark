      "name": "HTML/XML tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#7E838B"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7398E8"
      }
    },
    {
      "name": "CSS property value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#71E8A1"
      }
    },
    {
      "name": "CSS selector tag",
      "scope": [
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#799EE9"
      }
    },
    {
      "name": "CSS selector attribute / pseudo",
      "scope": [
        "entity.other.attribute-name.css",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#E87396"
      }
    },
    {
      "name": "CSS class / id selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#77CBE9"
      }
    },
    {
      "name": "CSS unit / numeric",
      "scope": [
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#E8E073"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#E7A36C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#70E19D"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#E78A6E"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#708EE8"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#C9CBCF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C9CBCF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#69C1E7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#70E19D"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#71CEE8"
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7E838B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown list bullet",
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#E87396"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#E78A6E",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#E7A36C",
        "fontStyle": "strikethrough"
      }
    }
  ],
