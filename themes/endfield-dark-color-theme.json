      "settings": {
        "foreground": "#6DC4E7"
      }
    },
    {
      "name": "LaTeX declared command name",
      "scope": "meta.parameter.newcommand.latex support.function.general.latex",
      "settings": {
        "foreground": "#6DC4E7",
        "fontStyle": "bold"
      }
    },
    {
